# ── Required ──────────────────────────────────────────────────────────────────
# Discord-токен бота. https://discord.com/developers/applications
DISCORD_TOKEN=

# ── Recommended ───────────────────────────────────────────────────────────────
# ID владельца — единственный, кто может вызывать /stats.
OWNER_ID=

# Список Guild-ID через запятую (для быстрой регистрации команд во время разработки).
# Пусто = глобальная регистрация (обновляется в Discord 15-60 минут).
# GUILD_IDS=123456789012345678,987654321098765432
GUILD_IDS=

# ── Optional ──────────────────────────────────────────────────────────────────
# Максимальный размер входного файла (МБ).
MAX_INPUT_MB=100

# Параллельные конверсии /gif.
CONCURRENT_CONVERTS=2

# Параллельные рендеры /edit.
CONCURRENT_RENDERS=1

# Рабочая директория для временных файлов и кэша.
TEMP_DIR=/tmp/yhil_work

# Путь к лог-файлу (RotatingFileHandler, 5 МБ × 3).
LOG_PATH=bot.log
