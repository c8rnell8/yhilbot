# Bot token. https://discord.com/developers/applications
DISCORD_TOKEN=

# Owner ID - the only user allowed to call /stats.
OWNER_ID=

# Comma-separated guild IDs for fast command registration during development.
# Empty = global registration (takes 15-60 min to propagate).
# GUILD_IDS=123456789012345678,987654321098765432
GUILD_IDS=

# Max input file size in MB.
MAX_INPUT_MB=100

# Parallel /gif conversions.
CONCURRENT_CONVERTS=2

# Parallel /edit renders.
CONCURRENT_RENDERS=1

# Working directory for temp files and cache.
TEMP_DIR=/tmp/yhil_work

# Log file path (RotatingFileHandler, 5 MB x 3).
LOG_PATH=bot.log
